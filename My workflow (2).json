        "jsCode": "const link = $json.job_link || '';\nconst source = $json.source || '';\n\n// Jobicy already has the correct company_name set upstream — don't overwrite it\nif (source === 'jobicy') {\n  return {\n    json: {\n      ...$json,\n      company_name: $json.company_name || 'unknown-company'\n    }\n  };\n}\n\nlet company = 'unknown-company';\n\nif (link.includes('greenhouse.io/')) {\n  company = link.split('greenhouse.io/')[1].split('/')[0];\n} else if (link.includes('lever.co/')) {\n  company = link.split('lever.co/')[1].split('/')[0];\n} else if (link.includes('ashbyhq.com/')) {\n  company = link.split('ashbyhq.com/')[1].split('/')[0];\n} else if (link.includes('myworkdayjobs.com')) {\n  const afterProtocol = link.split('//')[1] || '';\n  company = afterProtocol.split('.')[0];\n}\n\nreturn {\n  json: {\n    ...$json,\n    company_name: company\n  }\n};"
      },
