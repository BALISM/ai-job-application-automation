      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const trustedDomains = [\n  'boards.greenhouse.io',\n  'jobs.lever.co',\n  'jobs.ashbyhq.com',\n  'myworkdayjobs.com'\n];\n\nconst link = ($json.job_link || $json.link || '').toLowerCase();\nconst source = $json.source || '';\n\n// Jobicy items are trusted by source, not by domain matching\nif (source === 'jobicy') {\n  const desc = ($json.job_description || '').toLowerCase();\n  // Jobicy is a remote-only board by definition — no extra remote check needed\n  return $json;\n}\n\nconst isTrusted = trustedDomains.some(domain => link.includes(domain));\nif (!isTrusted) {\n  return null;\n}\n\nconst desc = ($json.job_description || $json.snippet || '').toLowerCase();\nconst title = ($json.job_title || $json.title || '').toLowerCase();\nconst isRemote = desc.includes('remote') || title.includes('remote');\n\nif (!isRemote) {\n  return null;\n}\n\nreturn $json;"
      },
