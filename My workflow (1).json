    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const trustedDomains = [\n  'boards.greenhouse.io',\n  'jobs.lever.co',\n  'jobs.ashbyhq.com',\n  'myworkdayjobs.com',\n  'remoteok.com'\n];\n\nconst link = $json.job_link || $json.link || '';\nconst isTrusted = trustedDomains.some(domain => link.includes(domain));\n\nif (!isTrusted) {\n  return null;\n}\n\n// RemoteOK is a remote-only job board by definition — skip the text check for it\nif (link.includes('remoteok.com')) {\n  return $json;\n}\n\nconst desc = ($json.job_description || $json.snippet || '').toLowerCase();\nconst title = ($json.job_title || $json.title || '').toLowerCase();\nconst isRemote = desc.includes('remote') || title.includes('remote');\n\nif (!isRemote) {\n  return null;\n}\n\nreturn $json;"
      },
